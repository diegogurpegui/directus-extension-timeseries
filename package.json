{
  "name": "dg-timeseries",
  "description": "Display timeseries from SQL queries in dashboard line and bar charts.",
  "icon": "show_chart",
  "version": "1.1.2",
  "author": "Diego H. Gurpegui (https://github.com/diegogurpegui)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/diegogurpegui/directus-extension-timeseries.git"
  },
  "homepage": "https://github.com/diegogurpegui/directus-extension-timeseries#readme",
  "bugs": {
    "url": "https://github.com/diegogurpegui/directus-extension-timeseries/issues"
  },
  "keywords": [
    "directus",
    "directus-extension",
    "directus-extension-bundle",
    "directus-extension-panel",
    "timeseries",
    "charts",
    "sql"
  ],
  "type": "module",
  "files": [
    "dist"
  ],
  "directus:extension": {
    "type": "bundle",
    "path": {
      "app": "dist/index.js",
      "api": "dist/endpoint.js"
    },
    "source": {
      "app": "src/index.ts",
      "api": "src/endpoint.ts"
    },
    "host": "^10.10.0",
    "entries": [
      {
        "type": "endpoint",
        "name": "dg-timeseries-sql",
        "source": "src/endpoint.ts"
      },
      {
        "type": "panel",
        "name": "dg-timeseries",
        "source": "src/index.ts"
      }
    ]
  },
  "scripts": {
    "build": "directus-extension build",
    "dev": "directus-extension build -w --no-minify",
    "link": "directus-extension link",
    "validate": "directus-extension validate",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@directus/extensions-sdk": "17.0.3",
    "@types/lodash": "^4.17.21",
    "typescript": "^5.9.3",
    "vue": "^3.5.24"
  },
  "dependencies": {
    "apexcharts": "^3.54.1",
    "lodash": "^4.17.21",
    "vue-i18n": "^11.2.1"
  }
}
